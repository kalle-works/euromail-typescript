{
  "name": "@euromail/sdk",
  "version": "0.2.0",
  "description": "Official TypeScript SDK for EuroMail transactional email service",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "rm -rf dist",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write"
  },
  "keywords": [
    "euromail",
    "email",
    "transactional",
    "smtp"
  ],
  "license": "MIT",
  "author": "Kalle Works <info@kalle.works>",
  "repository": {
    "type": "git",
    "url": "https://github.com/kalle-works/euromail-typescript.git"
  },
  "homepage": "https://euromail.dev",
  "bugs": {
    "url": "https://github.com/kalle-works/euromail-typescript/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
